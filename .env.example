EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Client DSN from Sentry: Project Settings → Client Keys (DSN). Leave empty to disable Sentry locally.
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_ENV=development
# Build-time only: auth token for sentry-cli when uploading source maps (e.g. EAS Build / export with @sentry/react-native). Not read by the app at runtime; set in CI or EAS secrets for release builds.
SENTRY_AUTH_TOKEN=...
# Local Supabase OAuth (not loaded by Expo): create supabase/.env with
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# See docs/development.md § Google sign-in (OAuth).
