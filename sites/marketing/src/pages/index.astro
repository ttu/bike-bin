---
import BaseLayout from '../layouts/BaseLayout.astro';
import PhoneFrame from '../components/PhoneFrame.astro';
import VideoCard from '../components/VideoCard.astro';

const title = 'Bike Bin - your bike parts inventory';
const description =
  'Catalog bike parts, tools, and builds in one inventory - photos, condition, and where they\'re stored. When you want to, list or find gear nearby and coordinate handoffs on your terms. From bikers to bikers.';

/** Framed app captures from `npm run capture:media` (see `public/captures/README.md`). */
const base = import.meta.env.BASE_URL;
const cap = (slug: string) => `${base}captures/framed/${slug}.png`;
const capRaw = (slug: string) => `${base}captures/raw/${slug}.png`;
const capVideo = (name: string) => `${base}captures/video/${name}.webm`;

/** Logical pixel size of framed PNGs (matches `capture:media` output at 3×). */
const captureW = 1618;
const captureH = 3196;

/** Viewport-only captures (no device chrome) — Playwright viewport 430×932 @ 1× logical. */
const rawViewportW = 430;
const rawViewportH = 932;
---

<BaseLayout title={title} description={description}>
  <a class="skip-link" href="#main">Skip to content</a>

  <header class="nav">
    <div class="nav-inner">
      <a class="brand" href={import.meta.env.BASE_URL}>
        <span class="brand-mark" aria-hidden="true"></span>
        <span class="brand-text">Bike Bin</span>
      </a>
      <nav class="nav-links" aria-label="Primary">
        <a href="#how-it-works">How it works</a>
        <a href="#features">Features</a>
        <a href="#open-source">Open source</a>
        <a class="nav-cta" href="https://app.bikebin.app">Open app</a>
      </nav>
    </div>
  </header>

  <main id="main">
    <section class="hero" aria-labelledby="hero-heading">
      <div class="hero-slant" aria-hidden="true"></div>
      <div class="hero-grid">
        <div class="hero-copy reveal">
          <p class="eyebrow">From bikers to bikers</p>
          <h1 id="hero-heading">
            Your parts and tools, organized.<span class="hl">Photos, condition, where they're stored - and search across all of it.</span>
          </h1>
          <p class="lead">
            One inventory for what you own - photos, condition, usage, and status - so you can find anything without a
            spreadsheet. Borrowing, selling, and lending are optional: list or search nearby when that moment comes, and
            coordinate handoffs on your terms.
          </p>
          <div class="hero-actions">
            <a class="btn btn-primary" href="https://app.bikebin.app">Open web app</a>
            <a class="btn btn-secondary" href="https://github.com/ttu/bike-bin">Source</a>
          </div>
          <ul class="hero-stats" aria-label="Highlights">
            <li><strong>Components and gear always lost?</strong><span>Catalog them in one bin - photos, condition, and where they're stored.</span></li>
            <li><strong>Don't remember what you own?</strong><span>Search your inventory instead of guessing in the workshop.</span></li>
            <li><strong>Need a tool without buying one?</strong><span>Check if someone nearby can loan it - distance-aware discovery when you list.</span></li>
            <li><strong>Got tools to spare?</strong><span>Sell or lend when you want - optional listing and handoffs you coordinate in-app.</span></li>
          </ul>
        </div>
        <div class="hero-visual reveal reveal-delay-1">
          <PhoneFrame
            videoSrc={capVideo('browse-flow')}
            posterSrc={capRaw('02-inventory-signed-in')}
            imageAlt="Screen recording: Bike Bin web app — inventory search, item detail, and edit on a phone."
            mockOverlay={false}
            width={rawViewportW}
            height={rawViewportH}
          />
        </div>
      </div>
    </section>

    <section class="section section-band section-band--alt" aria-labelledby="story-heading">
      <div class="section-inner split split--reverse">
        <div class="split-copy reveal">
          <p class="eyebrow">On the go</p>
          <h2 id="story-heading">Your inventory comes first</h2>
          <p class="section-lead muted">
            The bin is home - search, groups, and messaging sit one layer out when you are ready to share or pick
            something up.
          </p>
          <p class="section-lead muted section-lead-follow">
            The same application on web, iOS, and Android. Use whatever device suits what you're doing - phone in
            the workshop, tablet on the couch, or browser at a desk - or stay signed in on all of them; your bin stays
            one account.
          </p>
        </div>
        <figure class="split-media split-media--capture split-media--phone reveal reveal-delay-1">
          <img
            src={capRaw('02-inventory-signed-in')}
            width={rawViewportW}
            height={rawViewportH}
            alt="Bike Bin inventory list on a phone: search, categories, and parts."
            loading="lazy"
            decoding="async"
          />
        </figure>
      </div>
    </section>

    <section id="how-it-works" class="section section-dark" aria-labelledby="how-heading">
      <div class="section-dark-grid" aria-hidden="true"></div>
      <div class="section-inner">
        <div class="section-head reveal">
          <p class="eyebrow eyebrow-dark">Three steps</p>
          <h2 id="how-heading">Your bin, then list or search, then chat</h2>
          <p class="section-lead section-lead-dark">
            Start by tracking what you own. When you want to share or pick something up, list or browse nearby, then use
            in-app messaging to agree on timing and pickup.
          </p>
        </div>
        <div class="video-grid">
          <div class="reveal reveal-delay-1">
            <VideoCard
              variant="dark"
              step="01 - Item detail"
              title="See each part clearly"
              body="Photos, condition, usage, and storage on one screen - so you always know what you have and where it lives."
              posterSrc={capRaw('03-item-detail')}
              imageAlt="Bike Bin item detail on a phone: photos, condition, and metadata."
              imageWidth={rawViewportW}
              imageHeight={rawViewportH}
              phonePreview
            />
          </div>
          <div class="reveal reveal-delay-2">
            <VideoCard
              variant="dark"
              step="02 - Search"
              title="List or find nearby"
              body="Offer borrow, donation, or sale; search with distance and availability - only when you need it."
              posterSrc={capRaw('05-search-results')}
              imageAlt="Bike Bin search results with distance on a phone."
              imageWidth={rawViewportW}
              imageHeight={rawViewportH}
              phonePreview
            />
          </div>
          <div class="reveal reveal-delay-3">
            <VideoCard
              variant="dark"
              step="03 - Messaging"
              title="Easy in-app messaging"
              body="Item-linked threads - agree on timing and pickup in one place without switching apps."
              posterSrc={capRaw('07-messages-thread')}
              imageAlt="Bike Bin conversation thread on a phone."
              imageWidth={rawViewportW}
              imageHeight={rawViewportH}
              phonePreview
            />
          </div>
        </div>
      </div>
    </section>

    <section id="features" class="section features-section section-band section-band--surface" aria-labelledby="features-heading">
      <div class="section-inner">
        <div class="section-head reveal">
          <p class="eyebrow">What's included</p>
          <h2 id="features-heading">Everything in one bin</h2>
          <p class="section-lead">
            Your personal inventory is the starting point. When you list something for others or arrange a handoff, you
            can use nearby search, groups, messaging, pickup areas, and ratings - each only as far as you take it.
          </p>
        </div>
        <div class="bento">
          <article class="bento-card bento-wide reveal">
            <h3>Personal inventory</h3>
            <p>
              The main job: know what you have - photos, condition, usage, and lifecycle status. Availability to borrow,
              donate, or sell is optional on each item.
            </p>
          </article>
          <article class="bento-card reveal reveal-delay-1">
            <h3>Distance search</h3>
            <p>When you list publicly, nearby riders can find your items by distance - not just scroll a generic catalog.</p>
          </article>
          <article class="bento-card reveal reveal-delay-2">
            <h3>Groups</h3>
            <p>Optional: scope visibility to clubs or crews instead of everyone.</p>
          </article>
          <article class="bento-card reveal reveal-delay-1">
            <h3>Messaging</h3>
            <p>Item-linked threads when you coordinate a handoff with someone else.</p>
          </article>
          <article class="bento-card reveal reveal-delay-2">
            <h3>Ratings</h3>
            <p>Lightweight feedback after handoffs when a transaction happens.</p>
          </article>
          <article class="bento-card reveal reveal-delay-3">
            <h3>Locations</h3>
            <p>Pickup areas without exposing full street addresses by default.</p>
          </article>
        </div>
      </div>
    </section>

    <section
      id="open-source"
      class="section section-band section-band--alt open-source-section"
      aria-labelledby="open-source-heading"
    >
      <div class="section-inner open-source-inner reveal">
        <p class="eyebrow">Community</p>
        <h2 id="open-source-heading">Open source</h2>
        <p class="section-lead muted open-source-copy">
          Bike Bin is open source. On GitHub you can suggest feature requests, report bugs, and contribute improvements
          to the app - whether that is code, docs, or ideas.
        </p>
        <div class="open-source-actions">
          <a class="btn btn-primary" href="https://github.com/ttu/bike-bin">Repository</a>
          <a class="btn btn-secondary" href="https://github.com/ttu/bike-bin/issues">Issues</a>
        </div>
      </div>
    </section>

    <section
      class="section section-band section-band--alt sustain-section"
      aria-labelledby="sustain-heading"
    >
      <div class="section-inner sustain-inner reveal">
        <p class="eyebrow">Fair expectations</p>
        <h2 id="sustain-heading">Why item limits, ads, or paid tiers may exist</h2>
        <p class="section-lead muted sustain-copy">
          Although Bike Bin is built by bikers for their own use, running it is not free. Storing your photos and
          inventory data, hosting the service, and moving that data over the network all cost money.
        </p>
        <p class="section-lead muted sustain-copy">
          On the free tier today you can track up to 1,000 items and attach up to 100 photos - a solid starting point
          with a clear ceiling so storage and bandwidth stay sustainable. There will always be a free tier that includes
          at least those same minimum limits. We may introduce ads or different subscription levels in the future (with
          higher allowances where it makes sense) so the service can stay online, scale safely, and keep improving. If
          those options appear, we will aim to keep them clear and proportionate.
        </p>
      </div>
    </section>

    <section class="cta section-band section-band--alt" aria-labelledby="cta-heading">
      <div class="cta-inner reveal">
        <p class="eyebrow eyebrow-cta">Ready</p>
        <h2 id="cta-heading">Open the bin on the web</h2>
        <p class="cta-lead">Use the same login you use in the app - no second account for the web.</p>
        <a class="btn btn-primary btn-lg" href="https://app.bikebin.app">app.bikebin.app</a>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="footer-inner">
      <p><strong>Bike Bin</strong> - iOS, Android, Web.</p>
      <p class="footer-meta">
        <a href="https://github.com/ttu/bike-bin">GitHub</a>
        <span aria-hidden="true">·</span>
        <span>Marketing · Astro</span>
      </p>
    </div>
  </footer>

</BaseLayout>

<style>
  /** Opacity only - avoid transform here; it fights .split-media rotate and breaks grid alignment. */
  @keyframes fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .reveal {
    opacity: 0;
    animation: fade-in 0.75s var(--ease-out) forwards;
  }

  .reveal-delay-1 {
    animation-delay: 0.08s;
  }
  .reveal-delay-2 {
    animation-delay: 0.16s;
  }
  .reveal-delay-3 {
    animation-delay: 0.24s;
  }

  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0.5rem;
    padding: 0.5rem 1rem;
    background: var(--color-ink);
    color: #fff;
    border-radius: 999px;
    z-index: 100;
    text-decoration: none;
  }

  .skip-link:focus {
    left: 0.5rem;
  }

  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    border-bottom: 1px solid var(--color-line);
    background: rgba(245, 240, 232, 0.82);
    backdrop-filter: blur(16px);
  }

  .nav-inner {
    max-width: 1160px;
    margin: 0 auto;
    padding: 0.9rem var(--space-page);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .brand-mark {
    width: 2.1rem;
    height: 2.1rem;
    border-radius: 0.55rem;
    background: linear-gradient(135deg, var(--color-brand) 0%, var(--color-brand-mid) 55%, var(--color-accent) 120%);
    box-shadow: 0 12px 32px rgba(0, 104, 87, 0.35);
  }

  .brand-text {
    font-size: 1.2rem;
  }

  .nav-links {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.65rem 1.15rem;
    font-size: 0.94rem;
  }

  .nav-links a {
    text-decoration: none;
    color: var(--color-muted);
    font-weight: 500;
  }

  .nav-links a:hover {
    color: var(--color-ink);
  }

  .nav-cta {
    padding: 0.5rem 1rem;
    border-radius: 999px;
    background: var(--color-ink);
    color: #fafaf9 !important;
    border: 1px solid transparent;
    font-weight: 600;
  }

  .nav-cta:hover {
    background: var(--color-ink-soft);
  }

  .hero {
    position: relative;
    padding: clamp(2.25rem, 6vw, 4.5rem) var(--space-page) 2.5rem;
    overflow: hidden;
    background: var(--color-paper);
    border-bottom: 1px solid var(--color-line);
  }

  /** Alternating bands (paper ↔ paper-deep) so sections read as distinct blocks. */
  .section-band--surface {
    background: var(--color-paper);
    border-bottom: 1px solid var(--color-line);
  }

  .section-band--alt {
    background: var(--color-paper-deep);
    border-bottom: 1px solid var(--color-line);
  }

  .hero-slant {
    position: absolute;
    top: -20%;
    right: -15%;
    width: min(70vw, 520px);
    height: 120%;
    background: linear-gradient(145deg, rgba(0, 104, 87, 0.09), rgba(234, 88, 12, 0.06));
    transform: rotate(-8deg);
    border-radius: 3rem;
    pointer-events: none;
  }

  .hero-grid {
    position: relative;
    max-width: 1160px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(0, 0.92fr);
    gap: clamp(1.75rem, 5vw, 3.5rem);
    align-items: center;
  }

  @media (max-width: 920px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }

    .hero-slant {
      opacity: 0.5;
    }
  }

  .hl {
    color: var(--color-accent);
    font-style: italic;
    font-size: 0.82em;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .eyebrow {
    margin: 0 0 0.85rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-brand-mid);
  }

  .eyebrow-dark {
    color: #fdba74;
  }

  .eyebrow-cta {
    color: var(--color-brand-mid);
  }

  h1 {
    margin: 0 0 1rem;
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5.5vw, 3.65rem);
    line-height: 1.02;
    letter-spacing: -0.035em;
    font-weight: 700;
  }

  #hero-heading {
    line-height: 1.12;
  }

  #hero-heading .hl {
    display: block;
    margin-top: 0.28em;
  }

  h2 {
    margin: 0 0 0.65rem;
    font-family: var(--font-display);
    font-size: clamp(1.85rem, 3.5vw, 2.45rem);
    letter-spacing: -0.03em;
    font-weight: 600;
    line-height: 1.15;
  }

  .lead {
    margin: 0 0 1.85rem;
    font-size: 1.08rem;
    line-height: 1.65;
    color: var(--color-muted);
    max-width: 44ch;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-bottom: 1.85rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.78rem 1.25rem;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.97rem;
    text-decoration: none;
    border: 1px solid transparent;
    transition:
      transform 0.2s var(--ease-out),
      box-shadow 0.2s var(--ease-out),
      background 0.2s var(--ease-out);
  }

  .btn:active {
    transform: translateY(1px);
  }

  .btn-primary {
    background: linear-gradient(135deg, var(--color-accent-bright), var(--color-accent));
    color: #fffaf0;
    box-shadow: 0 16px 44px rgba(194, 65, 12, 0.35);
  }

  .btn-primary:hover {
    box-shadow: 0 22px 55px rgba(194, 65, 12, 0.42);
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.65);
    color: var(--color-ink);
    border-color: var(--color-line-strong);
    backdrop-filter: blur(8px);
  }

  .btn-secondary:hover {
    background: #fff;
  }

  .btn-lg {
    padding: 0.95rem 1.5rem;
    font-size: 1.05rem;
  }

  .hero-stats {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.85rem;
    list-style: none;
    margin: 0;
    padding: 0;
    max-width: 640px;
  }

  @media (max-width: 520px) {
    .hero-stats {
      grid-template-columns: 1fr;
    }
  }

  .hero-stats li {
    padding: 0.8rem 0.9rem;
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.55);
    border: 1px solid var(--color-line);
    box-shadow: var(--shadow-card);
  }

  .hero-stats strong {
    display: block;
    font-size: 0.92rem;
    font-family: var(--font-display);
  }

  .hero-stats span {
    font-size: 0.78rem;
    color: var(--color-muted);
  }

  .hero-visual {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .section {
    padding: clamp(3rem, 8vw, 5.5rem) var(--space-page);
  }

  .section-inner {
    max-width: 1160px;
    margin: 0 auto;
  }

  .section-head {
    max-width: 560px;
    margin-bottom: 2.25rem;
  }

  .section-lead {
    margin: 0;
    font-size: 1.06rem;
    line-height: 1.65;
    color: var(--color-muted);
  }

  .muted {
    color: var(--color-muted) !important;
  }

  .section-lead-follow {
    margin-top: 0.65rem;
  }

  .section-dark {
    position: relative;
    color: #e7e5e4;
    padding: clamp(3.5rem, 9vw, 6rem) var(--space-page);
    overflow: hidden;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .section-dark-grid {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 50% at 10% 0%, rgba(45, 212, 191, 0.12), transparent 55%),
      radial-gradient(ellipse 60% 45% at 90% 20%, rgba(234, 88, 12, 0.1), transparent 50%),
      linear-gradient(180deg, #0f172a 0%, #020617 100%);
    z-index: 0;
  }

  .section-dark .section-inner {
    position: relative;
    z-index: 1;
  }

  .section-dark h2 {
    color: #fafaf9;
  }

  .section-lead-dark {
    color: rgba(231, 229, 228, 0.88) !important;
  }

  .video-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.1rem;
    align-items: stretch;
  }

  .video-grid > .reveal {
    display: flex;
    min-height: 0;
  }

  .video-grid > .reveal > :global(article.card) {
    flex: 1;
    width: 100%;
    min-width: 0;
  }

  @media (max-width: 960px) {
    .video-grid {
      grid-template-columns: 1fr;
    }
  }

  .split {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
    gap: clamp(1.75rem, 4vw, 3rem);
    align-items: start;
  }

  @media (max-width: 900px) {
    .split {
      grid-template-columns: 1fr;
    }
  }

  /**
   * Wide only: image left / text right. grid-template-areas keeps one row, aligned tops.
   * DOM order stays copy then figure for screen readers.
   */
  @media (min-width: 901px) {
    .split--reverse {
      grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
      grid-template-rows: auto;
      grid-template-areas: 'media copy';
    }

    .split--reverse .split-media {
      grid-area: media;
      align-self: start;
    }

    .split--reverse .split-copy {
      grid-area: copy;
      align-self: start;
    }
  }

  .split-media {
    margin: 0;
    padding: 0;
    border-radius: var(--radius-xl);
    overflow: hidden;
    border: 1px solid var(--color-line);
    box-shadow: var(--shadow-soft);
    background: #fff;
    align-self: start;
  }

  .split-media img {
    display: block;
    width: 100%;
    height: auto;
  }

  .split-media--capture {
    background: #0f172a;
  }

  .split-media--capture img {
    width: 100%;
    max-height: min(72vh, 640px);
    margin: 0 auto;
    object-fit: contain;
    object-position: center top;
  }

  /**
   * Raw viewport inside a modest device bezel (readable as a phone, not the heavy framed PNG).
   */
  .split-media--capture.split-media--phone {
    max-width: min(300px, 100%);
    margin-inline: auto;
    padding: 0.52rem;
    border-radius: 1.9rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow:
      0 0 0 1px rgba(0, 0, 0, 0.45) inset,
      0 16px 44px rgba(12, 15, 14, 0.22),
      0 0 1px rgba(28, 25, 23, 0.2);
    background: linear-gradient(155deg, #353230 0%, #1c1917 38%, #0a0a0a 100%);
  }

  .split-media--capture.split-media--phone img {
    max-height: none;
    display: block;
    width: 100%;
    height: auto;
    border-radius: 1.4rem;
    box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.25);
  }

  .features-section {
    padding-bottom: clamp(2rem, 5vw, 3rem);
  }

  .open-source-inner {
    max-width: 640px;
  }

  .open-source-copy {
    margin: 0 0 1.35rem;
  }

  .open-source-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
  }

  .sustain-copy {
    margin: 0;
    max-width: 58ch;
  }

  .sustain-copy + .sustain-copy {
    margin-top: 0.65rem;
  }

  .bento {
    display: grid;
