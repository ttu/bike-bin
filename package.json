{
  "name": "bike-bin",
  "version": "1.0.0",
  "description": "**From bikers to bikers.**",
  "main": "expo-router/entry",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "npm run db:start && expo start",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:seed": "supabase db reset && node scripts/seed-images.mjs",
    "db:nuke": "supabase stop --no-backup && supabase start && node scripts/seed-images.mjs",
    "db:enable-signup": "sed -i '' 's/enable_signup = false/enable_signup = true/g' supabase/config.toml && supabase stop && supabase start",
    "db:status": "supabase status",
    "dev:fresh": "sed -i '' 's/enable_signup = false/enable_signup = true/g' supabase/config.toml && supabase stop --no-backup && supabase start && node scripts/seed-images.mjs && expo start",
    "dev:web": "expo start --web",
    "dev:android": "expo start --android",
    "dev:ios": "expo start --ios",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write '**/*.{ts,tsx,json,md}'",
    "format:check": "prettier --check '**/*.{ts,tsx,json,md}'",
    "test": "npm run test:unit --",
    "test:unit": "jest",
    "test:watch": "npm run test:unit -- --watch",
    "test:coverage": "npm run test:unit -- --coverage",
    "test:rls": "jest --config jest.rls.config.js",
    "test:rls:isolated": "bash scripts/run-isolated-db-tests.sh rls",
    "test:e2e:isolated": "bash scripts/run-isolated-db-tests.sh e2e",
    "test:db:isolated": "bash scripts/run-isolated-db-tests.sh both",
    "type-check": "tsc --noEmit",
    "test:e2e": "npx playwright test",
    "capture:media": "playwright test -c playwright.media.config.ts",
    "validate": "npm run format:check && npm run lint && npm run type-check && npm test",
    "marketing:dev": "npm run dev --prefix sites/marketing",
    "marketing:build": "npm run build --prefix sites/marketing",
    "marketing:test": "npm run test --prefix sites/marketing",
    "build:web": "expo export --platform web",
    "deploy:web": "npm run build:web && eas deploy",
    "deploy:web:prod": "npm run build:web && eas deploy --prod",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "ios:prebuild": "expo prebuild --platform ios --clean",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "GPL-3.0",
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@expo-google-fonts/manrope": "^0.4.2",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "@sentry/react-native": "~7.11.0",
    "@supabase/supabase-js": "^2.99.2",
    "@tanstack/query-async-storage-persister": "^5.90.24",
    "@tanstack/react-query": "^5.90.21",
    "expo": "~55.0.11",
    "expo-blur": "~55.0.12",
    "expo-constants": "~55.0.11",
    "expo-file-system": "~55.0.14",
    "expo-font": "~55.0.6",
    "expo-image": "~55.0.8",
    "expo-image-manipulator": "~55.0.13",
    "expo-image-picker": "~55.0.16",
    "expo-linear-gradient": "~55.0.11",
    "expo-linking": "~55.0.11",
    "expo-localization": "~55.0.11",
    "expo-router": "~55.0.10",
    "expo-splash-screen": "~55.0.15",
    "expo-status-bar": "~55.0.5",
    "i18next": "^25.8.18",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^16.5.8",
    "react-native": "0.83.4",
    "react-native-paper": "^5.15.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "fflate": "^0.8.2",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "55.0.13",
    "lint-staged": "^16.4.0",
    "openai": "^6.32.0",
    "prettier": "^3.8.1",
    "react-test-renderer": "19.2.0",
    "sharp": "^0.34.5",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
