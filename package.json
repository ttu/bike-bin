{
  "name": "bike-bin",
  "version": "1.0.0",
  "description": "**From bikers to bikers.**",
  "main": "expo-router/entry",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "dev": "npm run db:start && expo start",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:status": "supabase status",
    "dev:web": "expo start --web",
    "dev:android": "expo start --android",
    "dev:ios": "expo start --ios",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write '**/*.{ts,tsx,json,md}'",
    "format:check": "prettier --check '**/*.{ts,tsx,json,md}'",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "type-check": "tsc --noEmit",
    "test:e2e": "npx playwright test",
    "validate": "npm run format:check && npm run lint && npm run type-check && npm test",
    "build:web": "expo export --platform web",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^3.0.1",
    "@react-native-community/netinfo": "^12.0.1",
    "@sentry/react-native": "~7.11.0",
    "@supabase/supabase-js": "^2.99.2",
    "@tanstack/query-async-storage-persister": "^5.90.24",
    "@tanstack/react-query": "^5.90.21",
    "expo": "^55.0.7",
    "expo-constants": "~55.0.8",
    "expo-linking": "~55.0.7",
    "expo-localization": "^55.0.9",
    "expo-router": "~55.0.6",
    "expo-status-bar": "~55.0.4",
    "i18next": "^25.8.18",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.8",
    "react-native": "0.83.2",
    "react-native-paper": "^5.15.0",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-vector-icons": "^10.3.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@playwright/test": "^1.58.2",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "@types/react-native": "^0.72.8",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.10",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "react-test-renderer": "^19.2.4",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
